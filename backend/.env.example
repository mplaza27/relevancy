# Backend environment variables
# Copy to .env and fill in real values

# Supabase direct connection (port 5432, NOT the pooler on 6543)
# Format: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:your-password@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# Embedding model (default: FremyCompany/BioLORD-2023, 768-dim, 512 tokens)
EMBEDDING_MODEL=FremyCompany/BioLORD-2023

# Cross-encoder for reranking (default: ncbi/MedCPT-Cross-Encoder)
CROSS_ENCODER_MODEL=ncbi/MedCPT-Cross-Encoder

# Disable cross-encoder if memory-constrained (default: true)
ENABLE_CROSS_ENCODER=true

# Max upload size in bytes (default: 50MB)
MAX_UPLOAD_SIZE=52428800

# Allowed CORS origins (comma-separated)
# Development: http://localhost:5173
# Production: https://your-site.pages.dev
CORS_ORIGINS=["http://localhost:5173"]
